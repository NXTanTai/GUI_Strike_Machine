   <string notr="true">
QMainWindow { background-color: #f8fafc; }
QWidget#centralwidget { background-color: #f8fafc; }
QLabel#label_title {
    color: #1e2937; font-family: "Segoe UI"; font-size: 20px;
    font-weight: 700; letter-spacing: 1px;
}
QLabel#label_subtitle {
    color: #64748b; font-family: "Segoe UI"; font-size: 11px; letter-spacing: 2px;
}
QFrame#frame_search {
    background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 10px;
}
QLineEdit#lineEdit_search {
    background-color: transparent; border: none; color: #1e2937;
    font-family: "Segoe UI"; font-size: 13px; padding: 6px 4px;
    selection-background-color: #3b82f6;
    selection-color: #ffffff;
}
QLabel#label_icon { color: #94a3b8; font-size: 15px; padding-left: 6px; }
QPushButton#btn_clear {
    background-color: transparent; border: none; color: #94a3b8;
    font-size: 16px; font-weight: bold; padding: 0px 8px; border-radius: 4px;
}
QPushButton#btn_clear:hover { color: #475569; background-color: #f1f5f9; }
QLabel#label_info { color: #64748b; font-family: "Segoe UI"; font-size: 11px; font-style: italic; }
QTableWidget {
    background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px;
    gridline-color: #f1f5f9; color: #334155; font-family: "Segoe UI"; font-size: 13px;
    selection-background-color: #dbeafe; selection-color: #1e40af; outline: none;
}
QTableWidget::item { padding: 8px 14px; border-bottom: 1px solid #f1f5f9; }
QTableWidget::item:selected { background-color: #dbeafe; color: #1e40af; }
QTableWidget::item:hover { background-color: #f8fafc; }
QHeaderView::section {
    background-color: #f8fafc; color: #1e40af; font-family: "Segoe UI";
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    padding: 10px 14px; border: none; border-bottom: 2px solid #3b82f6;
    border-right: 1px solid #e2e8f0;
}
QHeaderView::section:last { border-right: none; }
QScrollBar:vertical { background: #f8fafc; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #cbd5e1; border-radius: 4px; min-height: 24px; }
QScrollBar::handle:vertical:hover { background: #94a3b8; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0px; }
QScrollBar:horizontal { background: #f8fafc; height: 8px; border-radius: 4px; }
QScrollBar::handle:horizontal { background: #cbd5e1; border-radius: 4px; min-width: 24px; }
QScrollBar::handle:horizontal:hover { background: #94a3b8; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0px; }
QStatusBar {
    background-color: #f1f5f9; color: #64748b; font-family: "Segoe UI";
    font-size: 11px; border-top: 1px solid #e2e8f0;
}
