	border: none;
}

QSpinBox {
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #F9FAFB;
}
QSpinBox:focus {
    border: 2px solid #0B7EC8;
    background-color: white;
}

QLineEdit {
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #F9FAFB;
}
