{
    "QCustomSlideMenu": {
        "left_side_menu_widget": {
            "defaultSize": {
                "width": 70,
                "height": "parent"
            },
            "collapsedSize": {
                "width": 70,
                "height": "parent"
            },
            "expandedSize": {
                "width": 175,
                "height": "parent"
            },
            "toggleButton": {
                "buttonName": "open_side_menu_btn"
            },
            "menuTransitionAnimation": {
                "animationDuration": 250,
                "animationEasingCurve": "Linear",
                "whenCollapsing": {
                    "animationDuration": 250,
                    "animationEasingCurve": "Linear"
                },
                "whenExpanding": {
                    "animationDuration": 250,
                    "animationEasingCurve": "Linear"
                }
            }
        }
    }
}