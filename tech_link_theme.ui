                           <item>
                            <widget class="QGroupBox" name="i_o_group_2">
                             <property name="font">
                              <font>
                               <family>Segoe UI</family>
                               <pointsize>16</pointsize>
                               <weight>75</weight>
                               <bold>true</bold>
                              </font>
                             </property>
                             <property name="styleSheet">
                              <string notr="true">QGroupBox {
    border: 2px solid #E5E5E5;
    border-radius: 6px;
    margin-top: 10px;
    padding-top: 10px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px 0 5px;
    color: #374151;
}

QLabel {
	color: #D12323;
	border: none;
}

QSpinBox {
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #F9FAFB;
}
QSpinBox:focus {
    border: 2px solid #0B7EC8;
    background-color: white;
}

QLineEdit {
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #F9FAFB;
}
QLineEdit:focus {
    border: 2px solid #0B7EC8;
    background-color: white;
}</string>
                             </property>
